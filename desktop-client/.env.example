# Public WebSocket endpoint of the deployed signaling server.
# Do not put TURN passwords or other secrets in this file: VITE_* values are
# embedded into the browser bundle and are visible to everyone who opens it.
VITE_SIGNALING_URL=wss://your-signaling-server.onrender.com/ws

# Needed only for a GitHub Pages project site. The GitHub Actions workflow
# sets it automatically, so leave it commented for local development.
# VITE_BASE_PATH=/your-repository-name/
