# Signaling/backend
PORT=8787
ALLOWED_ORIGINS=https://watch.example.com
MESSAGE_RATE_LIMIT_PER_MINUTE=180
RECONNECT_GRACE_MS=20000
ROOM_TTL_MS=21600000
MAX_PARTICIPANTS=4

# ICE. STUN_URLS is optional; TURN is required for reliable production NAT traversal.
STUN_URLS=stun:stun.l.google.com:19302
TURN_URLS=turn:turn.example.com:3478,turns:turn.example.com:5349
TURN_SHARED_SECRET=replace-with-the-secret-configured-on-your-turn-server
TURN_CREDENTIAL_TTL_SECONDS=3600

# Desktop release build only. The combined browser deployment uses its own origin automatically.
VITE_SIGNALING_URL=wss://watch.example.com/ws
VITE_PUBLIC_APP_URL=https://watch.example.com
